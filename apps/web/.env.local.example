# ─── Provider selection ──────────────────────────────────────────────────
# Pick one. If you set VERRIC_PROVIDER explicitly, Verric uses that.
# If you don't set it, Verric uses OpenAI when OPENAI_API_KEY is present,
# and falls back to a local Ollama otherwise. There is NO mock fallback —
# if the configured provider can't be reached, the run fails honestly.
VERRIC_PROVIDER=openai     # openai | anthropic | ollama

# ─── OpenAI ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Anthropic ───────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ─── Ollama (local, fully offline) ───────────────────────────────────────
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.1

# ─── Receipts ────────────────────────────────────────────────────────────
# HMAC-SHA-256 signing key for the cryptographic receipt that ships with
# every successful run. Anyone with this key can independently verify a
# receipt later. Treat it like a secret. If unset, receipts are produced
# with a non-secret default key (still verifiable, but anyone can forge).
VERRIC_SIGNING_KEY=change-me-to-a-real-secret
